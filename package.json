{
  "name": "ultimate-team",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @ultimate-team/api",
    "dev:web": "npm run dev --workspace @ultimate-team/web",
